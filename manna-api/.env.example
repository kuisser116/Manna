# ============================================================
#  MANNA API — Variables de Entorno
#  INSTRUCCIONES: Copia este archivo como ".env" y llena
#  los valores. NUNCA subas el .env a GitHub.
# ============================================================

# ── Aplicación ───────────────────────────────────────────────
PORT=3000
JWT_SECRET=CAMBIA_ESTO_POR_UNA_FRASE_SECRETA_LARGA
ENCRYPTION_KEY=EXACTAMENTE_32_CARACTERES_AQUI!!  # AES-256 necesita exactamente 32 chars

# ── Stellar (Testnet) ────────────────────────────────────────
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
# La clave secreta de la cuenta "administradora" que firma transacciones del sistema
# Créala en: https://laboratory.stellar.org/#account-creator?network=test
ADMIN_SECRET_KEY=TU_CLAVE_SECRETA_STELLAR_AQUI

# ── Wallets del Sistema (Tesorería y Granero) ────────────────
SYSTEM_WALLET_PUBLIC_KEY=TU_PUBLIC_KEY_TESORERIA
BARN_WALLET_PUBLIC_KEY=TU_PUBLIC_KEY_GRANERO

# ── IPFS (Pinata) ────────────────────────────────────────────
# Obtén tu JWT en: https://app.pinata.cloud/developers/api-keys
PINATA_JWT=TU_JWT_DE_PINATA_AQUI
PINATA_GATEWAY=https://gateway.pinata.cloud

# ── Video (Livepeer) ─────────────────────────────────────────
# Obtén tu API Key en: https://livepeer.studio
LIVEPEER_API_KEY=TU_API_KEY_DE_LIVEPEER
LIVEPEER_TEST_MODE=true
TEST_VIDEO_URL=https://commondatastorage.googleapis.com/gtv-videos-bucket/sample/BigBuckBunny.mp4

# ── Almacenamiento (Cloudflare R2) ───────────────────────────
# Obtén estas claves en: https://dash.cloudflare.com -> R2 -> Manage R2 API Tokens
CLOUDFLARE_R2_ACCOUNT_ID=TU_ACCOUNT_ID
CLOUDFLARE_R2_ACCESS_KEY_ID=TU_ACCESS_KEY
CLOUDFLARE_R2_SECRET_ACCESS_KEY=TU_SECRET_KEY
CLOUDFLARE_R2_BUCKET_NAME=manna-media
CLOUDFLARE_R2_PUBLIC_URL=https://TU_BUCKET.r2.dev

# ── Anti-Bots y Seguridad ────────────────────────────────────
GOOGLE_CLIENT_ID=TU_GOOGLE_CLIENT_ID.apps.googleusercontent.com
RECAPTCHA_SECRET_KEY=TU_RECAPTCHA_SECRET_KEY

# ── Anchor SEP-24 (Retiros con MoneyGram) ────────────────────
# Para testnet usa el entorno de demo de MoneyGram
MONEYGRAM_ANCHOR_URL=https://extstellar.moneygram.com

# ── Webhooks (Opcional para desarrollo local) ────────────────
# Descomenta y usa ngrok para recibir notificaciones de Livepeer
# WEBHOOK_URL=https://TU_URL.ngrok.io/api/webhooks/livepeer
