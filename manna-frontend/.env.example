# ============================================================
#  MANNA FRONTEND — Variables de Entorno
#  INSTRUCCIONES: Copia este archivo como ".env" y llena
#  los valores. NUNCA subas el .env a GitHub.
#  IMPORTANTE: Todas las variables DEBEN empezar con VITE_
# ============================================================

# ── URL del Backend ───────────────────────────────────────────
# En desarrollo local siempre apunta a tu máquina. En producción
# cambia esto por la URL de tu servidor desplegado (ej: Render, Railway).
VITE_API_URL=http://localhost:3000

# ── Stellar ───────────────────────────────────────────────────
VITE_STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# ── IPFS (Pinata) ────────────────────────────────────────────
VITE_PINATA_GATEWAY=https://gateway.pinata.cloud

# ── Anti-Bots (Google) ───────────────────────────────────────
# El CLIENT_ID del frontend va aquí (diferente al del backend)
# Obtén ambos en: https://console.cloud.google.com
VITE_GOOGLE_CLIENT_ID=TU_GOOGLE_CLIENT_ID.apps.googleusercontent.com
VITE_RECAPTCHA_SITE_KEY=TU_RECAPTCHA_SITE_KEY
